// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  RENTER
  OWNER
  ADMIN
}

enum VehicleType {
  CAR
  BIKE
  SCOOTER
  BICYCLE
}

enum VehicleStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  UNAVAILABLE
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
}

enum DocumentType {
  RC
  INSURANCE
  PUC
  DRIVING_PERMIT
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  role          Role           @default(RENTER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  vehicles      Vehicle[]

  @@map("users")
  bookings Booking[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Vehicle {
  id                 String                @id @default(uuid())
  name               String
  type               VehicleType
  brand              String
  model              String
  variant            String?
  year               Int
  registrationNumber String                @unique
  fuelType           FuelType
  transmission       Transmission
  color              String
  seatingCapacity    Int
  mileage            Float
  description        String
  city               String
  state              String
  pickupAddress      String
  latitude           Float
  longitude          Float
  pricePerHour       Float
  pricePerDay        Float
  pricePerWeek       Float
  securityDeposit    Float
  status             VehicleStatus         @default(DRAFT)
  ownerId            String
  owner              User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  images             VehicleImage[]
  documents          VehicleDocument[]
  availabilities     VehicleAvailability[]

  @@index([ownerId])
  @@index([status])
  @@index([city])
  @@index([type])
  @@map("vehicles")
}

model VehicleImage {
  id           String   @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url          String
  publicId     String?
  isPrimary    Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([vehicleId])
  @@map("vehicle_images")
}

model VehicleDocument {
  id        String       @id @default(uuid())
  vehicleId String
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type      DocumentType
  url       String
  publicId  String?
  createdAt DateTime     @default(now())

  @@index([vehicleId])
  @@map("vehicle_documents")
}

model VehicleAvailability {
  id        String             @id @default(uuid())
  vehicleId String
  vehicle   Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  status    AvailabilityStatus @default(AVAILABLE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([vehicleId])
  @@index([startDate, endDate])
  @@map("vehicle_availabilities")
}


// ---------- Booking System ----------
enum BookingDuration {
  HOURLY
  DAILY
  WEEKLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  UPI
  CARD
  NET_BANKING
  WALLET
  CASH
}

model Booking {
  id               String          @id @default(uuid())
  userId           String
  vehicleId        String
  startTime        DateTime
  endTime          DateTime
  duration         BookingDuration
  status           BookingStatus   @default(PENDING)
  securityDeposit  Float
  totalAmount      Float
  couponId   String?
  paymentId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id])
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  coupon      Coupon? @relation(fields: [couponId], references: [id])
  payment     Payment? @relation(fields: [paymentId], references: [id])
}

model Payment {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  amount       Float
  method       PaymentMethod
  status       PaymentStatus
  razorpayId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  booking      Booking  @relation(fields: [bookingId], references: [id])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String   // "percentage" | "fixed"
  discountValue Float
  expiresAt     DateTime?
  maxUses       Int?     // null = unlimited
  uses          Int      @default(0)
  createdAt     DateTime @default(now())
}

model Transaction {
  id           String   @id @default(uuid())
  bookingId    String
  amount       Float
  type         String   // "deposit", "payment", "refund"
  gatewayRef   String?  // optional Razorpay reference
  status       String   // "success", "failed"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  booking      Booking  @relation(fields: [bookingId], references: [id])
}

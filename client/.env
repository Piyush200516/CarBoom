# ──────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT: Leave VITE_API_URL unset — the Vite dev proxy (vite.config.ts)
# will forward /api/v1/* to http://localhost:5000 automatically.
#
# PRODUCTION (Vercel): Set this to your deployed backend URL, e.g.:
#   VITE_API_URL=https://your-carboom-backend.onrender.com/api/v1
# ──────────────────────────────────────────────────────────────────────────────
# VITE_API_URL=https://your-carboom-backend.onrender.com/api/v1
